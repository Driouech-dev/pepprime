---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import { products } from '../data/products';

const featuredProducts = products.filter((product) => product.featured).slice(0, 6);
---

<BaseLayout title="pepprime | Home" description="pepprime research peptide catalog with product pricing and direct inquiry.">
  <Hero />

  <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 sm:py-16">
    <div class="grid gap-6 lg:grid-cols-[0.96fr_1.04fr]">
      <div class="rounded-[2rem] border border-blue-100 bg-white p-6 shadow-soft sm:p-8">
        <div class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-blue">Company</div>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950">pepprime</h2>
        <p class="mt-4 text-sm leading-8 text-slate-600 sm:text-base">
          pepprime is a peptide-focused company presentation built around premium blue branding, visible product pricing, and direct global inquiry.
        </p>
        <p class="mt-4 text-sm leading-8 text-slate-600 sm:text-base">
          The website keeps attention on company image, current peptide products, clean photography, and fast customer communication.
        </p>
      </div>

      <div class="rounded-[2rem] border border-blue-100 bg-white p-6 shadow-soft sm:p-8">
        <div class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-blue">Products</div>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950">Current peptide range</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {[
            ['Retatrutide', '5mg / 10mg / 15mg / 20mg / 30mg'],
            ['Tesamorelin', '10mg'],
            ['MOTS-C', '10mg'],
            ['GHK-CU', '50mg / 100mg'],
            ['BPC-157', '5mg / 10mg'],
            ['TB500', '5mg / 10mg'],
          ].map(([title, copy]) => (
            <div class="rounded-3xl bg-blue-50/60 p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-blue-50 hover:shadow-glow">
              <div class="font-semibold text-slate-950">{title}</div>
              <div class="mt-2 text-sm leading-7 text-slate-600">{copy}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 sm:py-8">
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <div class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-blue">Featured products</div>
        <h2 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950">Product selection</h2>
      </div>
      <a href="/products" class="text-sm font-semibold text-brand-navy transition hover:text-brand-blue">See all products</a>
    </div>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {featuredProducts.map((product) => <ProductCard product={product} />)}
    </div>
  </section>
</BaseLayout>
