---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products } from '../../data/products';

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: {
      product,
      related: products.filter((item) => item.slug !== product.slug).slice(0, 3)
    }
  }));
}

const { product, related } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`pepprime | ${product.name}`} description={product.shortDescription}>
  <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 sm:py-16">
    <div class="grid gap-8 lg:grid-cols-[1.02fr_0.98fr] lg:gap-10">
      <div class="overflow-hidden rounded-[2rem] border border-blue-100 bg-white shadow-soft">
        <div class="aspect-[4/3] bg-blue-50/50">
          <img src={product.image} alt={product.name} class="h-full w-full object-cover" />
        </div>
      </div>

      <div>
        <div class="inline-flex rounded-full bg-brand-softblue px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-brand-navy">
          {product.category}
        </div>

        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950">{product.name}</h1>
        <p class="mt-4 text-base leading-8 text-slate-600 sm:text-lg">{product.shortDescription}</p>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="rounded-[1.5rem] border border-blue-100 bg-white p-5 shadow-soft">
            <div class="text-xs uppercase tracking-[0.2em] text-slate-400">Price</div>
            <div class="mt-2 text-lg font-semibold text-slate-950">{product.price}</div>
          </div>

          <div class="rounded-[1.5rem] border border-blue-100 bg-white p-5 shadow-soft">
            <div class="text-xs uppercase tracking-[0.2em] text-slate-400">Format</div>
            <div class="mt-2 text-sm font-semibold text-slate-950">{product.size}</div>
          </div>
        </div>

        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a
            href={`${base}contact/`}
            class="rounded-full bg-brand-navy px-6 py-3.5 text-center text-sm font-semibold text-white shadow-soft transition hover:bg-brand-blue"
          >
            Request Quote
          </a>

          <a
            href="https://wa.me/8615102940126"
            target="_blank"
            rel="noreferrer"
            class="rounded-full border border-blue-200 px-6 py-3.5 text-center text-sm font-semibold text-slate-700 transition hover:border-blue-300 hover:bg-blue-50"
          >
            WhatsApp
          </a>
        </div>

        <div class="mt-8 rounded-[2rem] border border-blue-100 bg-white p-6 shadow-soft">
          <h2 class="text-xl font-semibold text-slate-950">Product highlights</h2>
          <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-600">
            {product.details.map((item: string) => <li>• {item}</li>)}
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-14">
      <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <div class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-blue">Related items</div>
          <h2 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950">More products</h2>
        </div>

        <a href={`${base}products/`} class="text-sm font-semibold text-brand-navy">
          Back to all products
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {related.map((item) => (
          <a
            href={`${base}products/${item.slug}/`}
            class="overflow-hidden rounded-[1.75rem] border border-blue-100 bg-white shadow-soft transition hover:-translate-y-1 hover:shadow-glow"
          >
            <div class="aspect-[4/3] overflow-hidden bg-blue-50/50">
              <img src={item.image} alt={item.name} class="h-full w-full object-cover" />
            </div>

            <div class="p-5">
              <div class="text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-blue">{item.category}</div>
              <h3 class="mt-2 text-xl font-semibold text-slate-950">{item.name}</h3>
              <div class="mt-2 text-sm font-semibold text-brand-navy">{item.price}</div>
              <p class="mt-3 text-sm leading-7 text-slate-600">{item.shortDescription}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
