---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { products } from '../data/products';
---

<BaseLayout title="pepprime | Products List" description="Products list for pepprime.">
  <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 sm:py-16">
    <div class="max-w-3xl">
      <div class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-blue">Products List</div>
      <h1 class="mt-2 text-4xl font-semibold tracking-tight text-slate-950">Research peptide catalog</h1>
      <p class="mt-4 text-sm leading-8 text-slate-600 sm:text-base">
        Browse the current pepprime product range with visible pricing, product photos, and direct inquiry options.
      </p>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {products.map((product) => <ProductCard product={product} />)}
    </div>
  </section>
</BaseLayout>
