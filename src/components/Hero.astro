<section class="relative overflow-hidden border-b border-blue-100 bg-white">
  <div class="absolute inset-0 bg-hero-grid bg-[size:24px_24px] [mask-image:linear-gradient(to_bottom,white,transparent_80%)]"></div>
  <div class="absolute inset-x-0 top-0 h-[460px] bg-[radial-gradient(circle_at_top_right,_rgba(59,130,246,0.18),_transparent_34%),radial-gradient(circle_at_top_left,_rgba(14,165,233,0.12),_transparent_28%)]"></div>
  <div class="relative mx-auto grid max-w-7xl gap-10 px-4 py-16 sm:px-6 sm:py-20 lg:grid-cols-[1.03fr_0.97fr] lg:items-center lg:py-24">
    <div>
      <div class="label-pill inline-flex">
        pepprime • Molecular Innovation
      </div>
      <h1 class="mt-5 max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">
        Advanced peptide products with fast response, clear pricing, and professional presentation.
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-8 text-slate-600 sm:text-lg">
        pepprime offers a modern peptide catalog built for global customers who want direct inquiry, visible prices, secure communication, and a strong biotech visual identity.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a href="/products" class="rounded-full bg-brand-navy px-6 py-3.5 text-center text-sm font-semibold text-white shadow-soft transition-all duration-300 hover:-translate-y-0.5 hover:bg-brand-blue hover:shadow-glow">
          View Products
        </a>
        <a href="/contact" class="rounded-full border border-blue-200 bg-white px-6 py-3.5 text-center text-sm font-semibold text-slate-700 transition-all duration-300 hover:-translate-y-0.5 hover:border-blue-300 hover:bg-blue-50">
          Contact Us
        </a>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        <div class="rounded-3xl border border-blue-100 bg-white p-4 shadow-soft transition-all duration-300 hover:-translate-y-1 hover:shadow-glow">
          <div class="text-2xl font-semibold text-slate-950">21+</div>
          <div class="mt-1 text-sm text-slate-600">Peptide products currently listed</div>
        </div>
        <div class="rounded-3xl border border-blue-100 bg-white p-4 shadow-soft transition-all duration-300 hover:-translate-y-1 hover:shadow-glow">
          <div class="text-2xl font-semibold text-slate-950">Worldwide</div>
          <div class="mt-1 text-sm text-slate-600">Fast shipping communication for global orders</div>
        </div>
        <div class="rounded-3xl border border-blue-100 bg-white p-4 shadow-soft transition-all duration-300 hover:-translate-y-1 hover:shadow-glow">
          <div class="text-2xl font-semibold text-slate-950">Blue Lab Style</div>
          <div class="mt-1 text-sm text-slate-600">Professional scientific branding and product display</div>
        </div>
      </div>
    </div>

    <div class="grid gap-4">
      <div class="overflow-hidden rounded-[2rem] border border-blue-100 bg-white shadow-soft transition-all duration-300 hover:-translate-y-1 hover:shadow-glow">
        <div class="relative">
          <img src="/images/shipping-team.png" alt="Shipping support" class="h-72 w-full object-cover sm:h-80" />
          <div class="label-pill absolute left-4 top-4">Fast Worldwide Shipping</div>
        </div>
        <div class="p-6">
          <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Reliable delivery support</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            Orders can be discussed directly by WhatsApp or email with clear communication for pricing, quantity, and destination details.
          </p>
        </div>
      </div>

      <div class="overflow-hidden rounded-[2rem] border border-blue-100 bg-white shadow-soft transition-all duration-300 hover:-translate-y-1 hover:shadow-glow">
        <div class="relative">
          <img src="/images/lab-scientist.png" alt="Scientist in laboratory" class="h-72 w-full object-cover sm:h-80" />
          <div class="label-pill absolute left-4 top-4">Laboratory Research</div>
        </div>
        <div class="p-6">
          <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Research-driven visual identity</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            pepprime combines scientific presentation, clean product photography, and direct inquiry for a more professional peptide storefront.
          </p>
        </div>
      </div>
    </div>
