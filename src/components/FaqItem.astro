---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<details class="group rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-soft">
  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-lg font-semibold text-slate-950">
    <span>{question}</span>
    <span class="rounded-full bg-slate-100 p-2 text-slate-500 transition group-open:rotate-45">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M5 12h14" />
      </svg>
    </span>
  </summary>
  <p class="pt-4 text-sm leading-7 text-slate-600">{answer}</p>
</details>
