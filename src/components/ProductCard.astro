---
import type { Product } from '../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<article class="group overflow-hidden rounded-[1.75rem] border border-blue-100 bg-white shadow-soft transition-all duration-300 hover:-translate-y-1 hover:shadow-glow">
  <a href={`${base}products/${product.slug}/`} class="block aspect-[4/3] overflow-hidden bg-slate-100">
    <img
      src={product.image}
      alt={product.name}
      class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
    />
  </a>

  <div class="p-5 sm:p-6">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <div class="label-pill text-[11px]">{product.category}</div>
        <h3 class="mt-3 text-xl font-semibold text-slate-950">
          <a href={`${base}products/${product.slug}/`}>{product.name}</a>
        </h3>
      </div>

      <div class="rounded-full bg-brand-softblue px-3 py-1 text-sm font-semibold text-brand-navy transition-all duration-300 group-hover:bg-brand-navy group-hover:text-white">
        {product.price}
      </div>
    </div>

    <p class="mt-3 text-sm leading-7 text-slate-600">{product.shortDescription}</p>
    <div class="mt-4 text-sm text-slate-500">{product.size}</div>

    <div class="mt-5 flex flex-col gap-3 sm:flex-row">
      <a
        href={`${base}products/${product.slug}/`}
        class="rounded-full bg-slate-950 px-4 py-3 text-center text-sm font-semibold text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-brand-navy"
      >
        View Details
      </a>

      <a
        href={`${base}contact/`}
        class="rounded-full border border-blue-200 px-4 py-3 text-center text-sm font-semibold text-slate-700 transition-all duration-300 hover:-translate-y-0.5 hover:border-blue-300 hover:bg-blue-50"
      >
        Request Quote
      </a>
    </div>
  </div>
</article>
